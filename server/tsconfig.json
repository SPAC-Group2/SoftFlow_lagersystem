{
  "compilerOptions": {
    "module": "commonjs",
    "lib": ["esnext"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*", "package.json"],
  "typeRoots": ["node_modules/@types"],
  "types": ["node", "express"]
}